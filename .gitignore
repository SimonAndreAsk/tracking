# Cursor IDE MCP descriptors (not part of tracking governance)
mcps/

# Automation secrets and local credentials (never commit)
automation/credentials/*
!automation/credentials/.gitkeep
*.credentials.json
**/oauth-client.json
**/oauth-token.json
service-account*.json
**/service-account*.json
*.pem
*.p12

# Environment files (never commit real values)
.env
.env.*
!.env.example
!**/.env.example
**/.env
!**/.env.example

# Node dependencies
automation/node_modules/
qa/node_modules/
node_modules/

# Playwright / QA artifacts
.playwright-mcp/
qa/.playwright-mcp/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
qa/test-results/
qa/playwright-report/
