# Copy to automation/.env (gitignored). Paths are relative to automation/ unless absolute.

# Auth: oauth (recommended) | service_account | adc (gcloud)
GTM_AUTH=oauth

# OAuth (Desktop client JSON + token from npm run gtm:auth) — see gtm/SETUP-OAUTH.md
GTM_OAUTH_CLIENT_PATH=credentials/oauth-client.json
GTM_OAUTH_TOKEN_PATH=credentials/oauth-token.json

# Service account (only if GTM UI accepts the SA email as a user)
GTM_SERVICE_ACCOUNT_KEY_PATH=credentials/gtm-service-account.json

# OAuth scopes (comma-separated). Use edit scope when provisioning tags/triggers.
# Read-only (audit, list, export):
GTM_SCOPES=https://www.googleapis.com/auth/tagmanager.readonly
# Full container edit (uncomment for sync/deploy scripts):
# GTM_SCOPES=https://www.googleapis.com/auth/tagmanager.edit.containers

# Optional: set after first successful gtm:accounts / gtm:containers run
GTM_ACCOUNT_ID=
GTM_CONTAINER_ID=
